    "/api/v1/comments": {
      "get": {
        "summary": "Get Comments",
        "description": "Analyst-booth commentary, ordered oldest-first (ascending `seq`).",
        "operationId": "get_comments_api_v1_comments_get",
        "parameters": [
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Return only comments with `seq` greater than this (live tail / forward polling).",
              "title": "Since"
            },
            "description": "Return only comments with `seq` greater than this (live tail / forward polling)."
          },
          {
            "name": "before",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Return only comments with `seq` less than this (older history / backward paging).",
              "title": "Before"
            },
            "description": "Return only comments with `seq` less than this (older history / backward paging)."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Cap the result to the most recent N comments of the matched window.",
              "title": "Limit"
            },
            "description": "Cap the result to the most recent N comments of the matched window."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CommentResponse"
                  },
                  "title": "Response Get Comments Api V1 Comments Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
